# ScoutFlow AI Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================================================
# LLM PROVIDER (Optional - works without API keys using local fallback)
# ============================================================================
LLM_PROVIDER=none
# Optional. Leave as "none" for deterministic fallback mode.


# OpenRouter optional provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_API_BASE=https://openrouter.ai/api/v1/chat/completions

# Gemini optional provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Groq optional provider (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_BASE=https://api.groq.com/openai/v1/chat/completions

# Hugging Face optional provider
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HUGGINGFACE_API_BASE=https://api-inference.huggingface.co/models

# ============================================================================
# OUTREACH DELIVERY (real send + reply tracking)
# ============================================================================
# Public base URL of this server (e.g. via ngrok) for provider webhooks.
PUBLIC_BASE_URL=

# Resend (email) - https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=ScoutFlow <onboarding@resend.dev>
RESEND_REPLY_TO=

# Twilio (SMS / WhatsApp) - https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=


# ============================================================================
# DATABASE CONNECTOR (Optional)
# ============================================================================
# Supported: postgresql, mysql, sqlite
DB_TYPE=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=candidates_db
DB_USER=your_user
DB_PASSWORD=your_password
DB_SSL=false
DB_TABLE=candidates

# For SQLite:
# DB_TYPE=sqlite
# DB_PATH=./data/candidates.db

# ============================================================================
# METABASE CONNECTOR (Optional)
# ============================================================================
METABASE_URL=https://your-metabase-instance.com
METABASE_API_KEY=your_metabase_api_key
METABASE_COLLECTION_ID=

# ============================================================================
# AUTHENTICATION (Optional)
# ============================================================================
# JSON array of users: [{"email":"admin@scoutflow.ai","password":"secret","name":"Admin","role":"admin"}]
AUTH_USERS=

# API Keys for programmatic access: [{"name":"API Key 1","key":"sk_live_xxx","permissions":["candidates:read","candidates:write"]}]
AUTH_API_KEYS=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development